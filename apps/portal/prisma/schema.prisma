generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// Parent account for multi-client ownership, support, and billing.
/// Operational records remain scoped to child organizations.
model Agency {
  id        String       @id @default(uuid())
  name      String
  status    AgencyStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  organizations Organization[]
  memberships   AgencyMembership[]
}

model Organization {
  id                                String          @id @default(uuid())
  agencyId                          String?
  portalVertical                    PortalVertical  @default(CONTRACTOR)
  name                              String
  legalName                         String?
  addressLine1                      String?
  addressLine2                      String?
  city                              String?
  state                             String?
  zip                               String?
  phone                             String?
  email                             String?
  website                           String?
  licenseNumber                     String?
  ein                               String?
  purchaseOrderPrefix               String          @default("PO")
  purchaseOrderNextNumber           Int             @default(1)
  estimatePrefix                    String          @default("EST")
  estimateNextNumber                Int             @default(1)
  invoicePrefix                     String          @default("INV")
  invoiceNextNumber                 Int             @default(1)
  invoicePaymentInstructions        String?
  invoiceTemplate                   String          @default("classic")
  invoiceCollectionsEnabled         Boolean         @default(true)
  invoiceCollectionsAutoSendEnabled Boolean         @default(false)
  invoiceFirstReminderLeadDays      Int             @default(2)
  invoiceOverdueReminderCadenceDays Int             @default(7)
  invoiceCollectionsMaxReminders    Int             @default(2)
  invoiceCollectionsUrgentAfterDays Int             @default(7)
  invoiceCollectionsFinalAfterDays  Int             @default(21)
  logoPhotoId                       String?         @unique
  invoiceSequence                   Int             @default(0)
  ghostBustingEnabled               Boolean         @default(false)
  voiceNotesEnabled                 Boolean         @default(false)
  metaCapiEnabled                   Boolean         @default(false)
  offlineModeEnabled                Boolean         @default(false)
  ghostBustingQuietHoursStart       Int             @default(1260)
  ghostBustingQuietHoursEnd         Int             @default(480)
  ghostBustingMaxNudges             Int             @default(2)
  ghostBustingTemplateText          String?
  allowWorkerLeadCreate             Boolean         @default(true)
  onboardingStep                    Int             @default(0)
  onboardingCompletedAt             DateTime?
  onboardingSkippedAt               DateTime?
  package                            OrganizationPackage @default(MESSAGING_ENABLED)
  smsFromNumberE164                 String?
  messagingLaunchMode               MessagingLaunchMode @default(LIVE_SMS)
  smsMonthlyLimit                   Int             @default(3000)
  smsHardStop                       Boolean         @default(true)
  aiMonthlyBudgetCents              Int             @default(1000)
  aiHardStop                        Boolean         @default(true)
  aiUserDailyRequestLimit           Int             @default(25)
  messageLanguage                   MessageLanguage @default(EN)
  smsTone                           SmsTone         @default(FRIENDLY)
  autoReplyEnabled                  Boolean         @default(true)
  followUpsEnabled                  Boolean         @default(true)
  autoBookingEnabled                Boolean         @default(true)
  smsGreetingLine                   String?
  smsWorkingHoursText               String?
  smsWebsiteSignature               String?
  smsQuietHoursStartMinute          Int             @default(480)
  smsQuietHoursEndMinute            Int             @default(1200)
  missedCallAutoReplyOn             Boolean         @default(false)
  missedCallAutoReplyBody           String?
  missedCallAutoReplyBodyEn         String?
  missedCallAutoReplyBodyEs         String?
  intakeAutomationEnabled           Boolean         @default(false)
  intakeAskLocationBody             String?
  intakeAskLocationBodyEn           String?
  intakeAskLocationBodyEs           String?
  intakeAskWorkTypeBody             String?
  intakeAskWorkTypeBodyEn           String?
  intakeAskWorkTypeBodyEs           String?
  intakeAskCallbackBody             String?
  intakeAskCallbackBodyEn           String?
  intakeAskCallbackBodyEs           String?
  intakeCompletionBody              String?
  intakeCompletionBodyEn            String?
  intakeCompletionBodyEs            String?
  createdAt                         DateTime        @default(now())

  users                         User[]
  customers                     Customer[]
  leads                         Lead[]
  jobs                          Job[]
  calls                         Call[]
  messages                      Message[]
  events                        Event[]
  communicationEvents           CommunicationEvent[]
  voicemailArtifacts            VoicemailArtifact[]
  smsTemplates                  SmsTemplate[]
  dashboardConfig               OrgDashboardConfig?
  budgetRequests                BudgetRequest[]
  adSpendEntries                AdSpendEntry[]
  marketingSpends               MarketingSpend[]
  leadNotes                     LeadNote[]
  leadPhotos                    LeadPhoto[]
  photos                        Photo[]
  leadMeasurements              LeadMeasurement[]
  integrationAccounts           IntegrationAccount[]
  integrationOAuthStates        IntegrationOAuthState[]
  importRuns                    ImportRun[]
  portableCustomers             PortableCustomer[]
  portableJobs                  PortableJob[]
  portableInvoices              PortableInvoice[]
  portableInvoiceLineItems      PortableInvoiceLineItem[]
  portablePayments              PortablePayment[]
  portableNotes                 PortableNote[]
  stripeConnection              OrganizationStripeConnection?
  calendarWorkerHours           WorkingHours[]
  calendarTimeOff               TimeOff[]
  calendarHolds                 CalendarHold[]
  calendarEventWorkers          CalendarEventWorker[]
  googleAccounts                GoogleAccount[]
  googleOAuthStates             GoogleOAuthState[]
  googleSyncJobs                GoogleSyncJob[]
  googleSyncJobAttempts         GoogleSyncJobAttempt[]
  invoices                      Invoice[]
  invoiceCollectionAttempts     InvoiceCollectionAttempt[]
  purchaseOrders                PurchaseOrder[]
  businessExpenses              BusinessExpense[]
  estimates                     Estimate[]
  recurringServicePlans         RecurringServicePlan[]
  estimateShareLinks            EstimateShareLink[]
  jobTrackingLinks              JobTrackingLink[]
  estimateDrafts                EstimateDraft[]
  crews                         Crew[]
  materials                     Material[]
  jobEvents                     JobEvent[]
  jobMeasurements               JobMeasurement[]
  jobMaterials                  JobMaterial[]
  jobLabor                      JobLabor[]
  cronRunLogs                   InternalCronRunLog[]
  metaCapiEvents                MetaCapiEvent[]
  clientMutationReceipts        ClientMutationReceipt[]
  usageByMonth                  OrganizationUsage[]
  aiUsageByMonth                AiUsage[]
  aiUserDayUsage                AiUserDayUsage[]
  smsDispatchQueue              SmsDispatchQueue[]
  leadConversationStates        LeadConversationState[]
  leadConversationAudits        LeadConversationAuditEvent[]
  messagingSettings             OrganizationMessagingSettings?
  twilioConfig                  OrganizationTwilioConfig?
  twilioConfigAuditLogs         TwilioConfigAuditLog[]
  blockedCallers                BlockedCaller[]
  smsConsents                   SmsConsent[]
  customerPortalAccounts        CustomerPortalAccount[]
  websiteLeadSources            WebsiteLeadSource[]
  websiteLeadSubmissionReceipts WebsiteLeadSubmissionReceipt[]
  buyerProjects                 BuyerProject[]
  buyerProjectShareLinks        BuyerProjectShareLink[]
  contractProjects              ContractProject[]

  agency    Agency? @relation(fields: [agencyId], references: [id], onDelete: SetNull)
  logoPhoto Photo?  @relation("OrganizationLogo", fields: [logoPhotoId], references: [id], onDelete: SetNull)

  organizationMemberships OrganizationMembership[]

  @@index([agencyId])
  @@index([portalVertical])
}

model CustomerPortalAccount {
  id          String           @id @default(uuid())
  orgId       String
  customerId  String           @unique
  userId      String?
  email       String
  status      MembershipStatus @default(ACTIVE)
  lastLoginAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  customer Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  user     User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([orgId, email])
  @@index([orgId, status])
  @@index([userId])
}

model WebsiteLeadSource {
  id              String    @id @default(uuid())
  orgId           String
  name            String
  description     String?
  hashedSecret    String
  encryptedSecret String
  allowedOrigin   String?
  active          Boolean   @default(true)
  rateLimitKey    String?
  lastUsedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  org         Organization                   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  submissions WebsiteLeadSubmissionReceipt[]

  @@index([orgId, active])
  @@index([active, updatedAt])
  @@index([rateLimitKey])
}

model WebsiteLeadSubmissionReceipt {
  id                    String   @id @default(uuid())
  sourceId              String
  orgId                 String
  idempotencyKey        String
  requestHash           String
  createdLeadId         String?
  createdCustomerId     String?
  createdBuyerProjectId String?
  createdAt             DateTime @default(now())

  source WebsiteLeadSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  org    Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([sourceId, idempotencyKey])
  @@index([orgId, createdAt])
  @@index([sourceId, createdAt])
  @@index([createdLeadId])
  @@index([createdBuyerProjectId])
}

model User {
  id                 String             @id @default(uuid())
  name               String?
  email              String             @unique
  phoneE164          String?
  role               Role               @default(CLIENT)
  calendarAccessRole CalendarAccessRole @default(WORKER)
  timezone           String?
  /// Legacy/default workspace during tenant-access rollout.
  /// Membership tables become the long-term authority.
  orgId              String?
  passwordHash       String?
  mustChangePassword Boolean            @default(false)
  emailVerified      DateTime?
  createdAt          DateTime           @default(now())

  org                           Organization?              @relation(fields: [orgId], references: [id])
  agencyMemberships             AgencyMembership[]
  assignedLeads                 Lead[]                     @relation("LeadAssignee")
  assignedEvents                Event[]                    @relation("EventAssignee")
  requestedBudgetChanges        BudgetRequest[]            @relation("BudgetRequestRequester")
  reviewedBudgetChanges         BudgetRequest[]            @relation("BudgetRequestReviewer")
  adSpendEntries                AdSpendEntry[]             @relation("AdSpendEntryCreator")
  marketingSpends               MarketingSpend[]           @relation("MarketingSpendCreator")
  createdLeads                  Lead[]                     @relation("LeadCreator")
  createdCustomers              Customer[]                 @relation("CustomerCreator")
  leadNotes                     LeadNote[]                 @relation("LeadNoteCreator")
  leadPhotos                    LeadPhoto[]                @relation("LeadPhotoCreator")
  leadMeasurements              LeadMeasurement[]          @relation("LeadMeasurementCreator")
  calendarCreatedEvents         Event[]                    @relation("EventCreator")
  calendarAssignedEvents        CalendarEventWorker[]      @relation("CalendarEventWorker")
  workingHours                  WorkingHours[]             @relation("WorkingHoursWorker")
  timeOffEntries                TimeOff[]                  @relation("TimeOffWorker")
  calendarHolds                 CalendarHold[]             @relation("CalendarHoldWorker")
  createdCalendarHolds          CalendarHold[]             @relation("CalendarHoldCreator")
  googleAccounts                GoogleAccount[]            @relation("GoogleAccountUser")
  googleOAuthStates             GoogleOAuthState[]         @relation("GoogleOAuthStateUser")
  googleSyncJobs                GoogleSyncJob[]            @relation("GoogleSyncJobUser")
  googleSyncRunsTriggered       GoogleSyncRun[]            @relation("GoogleSyncRunTrigger")
  googleSyncJobAttempts         GoogleSyncJobAttempt[]     @relation("GoogleSyncJobAttemptUser")
  createdInvoices               Invoice[]                  @relation("InvoiceCreator")
  createdPurchaseOrders         PurchaseOrder[]            @relation("PurchaseOrderCreator")
  createdBusinessExpenses       BusinessExpense[]          @relation("BusinessExpenseCreator")
  createdEstimates              Estimate[]                 @relation("EstimateCreator")
  createdEstimateShareLinks     EstimateShareLink[]        @relation("EstimateShareCreator")
  createdJobTrackingLinks       JobTrackingLink[]          @relation("JobTrackingLinkCreator")
  createdEstimateDrafts         EstimateDraft[]            @relation("EstimateDraftCreator")
  createdRecurringServicePlans  RecurringServicePlan[]     @relation("RecurringServicePlanCreator")
  createdJobs                   Job[]                      @relation("JobCreator")
  jobEvents                     JobEvent[]                 @relation("JobEventActor")
  estimateActivities            EstimateActivity[]         @relation("EstimateActivityActor")
  accounts                      Account[]
  sessions                      Session[]
  resetTokens                   PasswordResetToken[]
  aiUserDayUsage                AiUserDayUsage[]
  communicationEvents           CommunicationEvent[]       @relation("CommunicationEventActor")
  organizationMemberships       OrganizationMembership[]
  twilioConfigAuditLogs         TwilioConfigAuditLog[]     @relation("TwilioConfigAuditActor")
  createdBlockedCallers         BlockedCaller[]            @relation("BlockedCallerCreator")
  importRuns                    ImportRun[]                @relation("ImportRunActor")
  invoiceCollectionAttempts     InvoiceCollectionAttempt[] @relation("InvoiceCollectionAttemptActor")
  customerPortalAccounts        CustomerPortalAccount[]
  createdBuyerProjectShareLinks BuyerProjectShareLink[]    @relation("BuyerProjectShareLinkCreator")
  createdContractProjects       ContractProject[]          @relation("ContractProjectCreator")

  @@index([orgId])
}

model AgencyMembership {
  id        String           @id @default(uuid())
  agencyId  String
  userId    String
  role      AgencyRole
  status    MembershipStatus @default(ACTIVE)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  agency Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([agencyId, userId])
  @@index([agencyId, status])
  @@index([userId, status])
}

model OrganizationMembership {
  id             String             @id @default(uuid())
  organizationId String
  userId         String
  role           CalendarAccessRole
  status         MembershipStatus   @default(ACTIVE)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId, status])
  @@index([userId, status])
}

model Lead {
  id                        String                 @id @default(uuid())
  orgId                     String
  customerId                String?
  createdByUserId           String?
  assignedToUserId          String?
  status                    LeadStatus             @default(NEW)
  priority                  LeadPriority           @default(MEDIUM)
  businessName              String?
  contactName               String?
  phoneE164                 String
  sourceType                LeadSourceType         @default(ORGANIC)
  preferredLanguage         LeadPreferredLanguage?
  sourceDetail              String?
  sourceChannel             LeadSourceChannel      @default(OTHER)
  utmSource                 String?
  utmMedium                 String?
  utmCampaign               String?
  attributionLocked         Boolean                @default(true)
  commissionEligible        Boolean                @default(false)
  city                      String?
  businessType              String?
  leadSource                LeadSource             @default(OTHER)
  firstContactedAt          DateTime?
  lastContactedAt           DateTime?
  lastInboundAt             DateTime?
  lastOutboundAt            DateTime?
  ghostNudgeCount           Int                    @default(0)
  lastGhostNudgeAt          DateTime?
  nextFollowUpAt            DateTime?
  intakeStage               LeadIntakeStage        @default(NONE)
  intakeLocationText        String?
  intakeWorkTypeText        String?
  intakePreferredCallbackAt DateTime?
  estimatedRevenueCents     Int?
  invoiceStatus             InvoiceStatus          @default(NONE)
  invoiceDraftText          String?
  invoiceDueAt              DateTime?
  invoiceLastAutoTaskAt     DateTime?
  notes                     String?
  latestEstimateId          String?
  estimateCount             Int                    @default(0)
  fbClickId                 String?
  fbBrowserId               String?
  createdAt                 DateTime               @default(now())
  updatedAt                 DateTime               @updatedAt

  org                  Organization                 @relation(fields: [orgId], references: [id], onDelete: Cascade)
  customer             Customer?                    @relation(fields: [customerId], references: [id], onDelete: SetNull)
  createdBy            User?                        @relation("LeadCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  assignedTo           User?                        @relation("LeadAssignee", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  calls                Call[]
  messages             Message[]
  events               Event[]
  jobs                 Job[]
  communicationEvents  CommunicationEvent[]
  voicemailArtifacts   VoicemailArtifact[]
  leadNotes            LeadNote[]
  leadPhotos           LeadPhoto[]
  measurements         LeadMeasurement[]
  estimates            Estimate[]                   @relation("EstimateLead")
  latestEstimate       Estimate?                    @relation("LeadLatestEstimate", fields: [latestEstimateId], references: [id], onDelete: SetNull)
  calendarHolds        CalendarHold[]
  invoices             Invoice[]
  metaCapiEvents       MetaCapiEvent[]
  smsDispatchQueue     SmsDispatchQueue[]
  conversationState    LeadConversationState?
  conversationAudits   LeadConversationAuditEvent[]
  blockedCallerEntries BlockedCaller[]              @relation("BlockedCallerSourceLead")
  smsConsents          SmsConsent[]
  buyerProject         BuyerProject?
  contractProjects     ContractProject[]

  @@index([orgId, status, createdAt])
  @@index([orgId, nextFollowUpAt])
  @@index([orgId, intakeStage])
  @@index([assignedToUserId, nextFollowUpAt])
  @@index([orgId, lastInboundAt])
  @@index([orgId, lastOutboundAt])
  @@index([orgId, ghostNudgeCount, lastGhostNudgeAt])
  @@index([orgId, invoiceStatus, updatedAt])
  @@index([latestEstimateId])
  @@index([customerId, updatedAt])
  @@index([createdByUserId, createdAt])
  @@index([orgId, sourceType, createdAt])
  @@index([orgId, sourceChannel, createdAt])
}

model BlockedCaller {
  id              String   @id @default(uuid())
  orgId           String
  phoneE164       String
  reason          String?
  sourceLeadId    String?
  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  sourceLead Lead?        @relation("BlockedCallerSourceLead", fields: [sourceLeadId], references: [id], onDelete: SetNull)
  createdBy  User?        @relation("BlockedCallerCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@unique([orgId, phoneE164])
  @@index([orgId, createdAt])
  @@index([sourceLeadId])
  @@index([createdByUserId, createdAt])
}

model SmsConsent {
  id                     String           @id @default(uuid())
  orgId                  String
  phoneE164              String
  customerId             String?
  leadId                 String?
  status                 SmsConsentStatus @default(UNKNOWN)
  source                 SmsConsentSource @default(SYSTEM)
  lastKeyword            String?
  lastMessageBodyPreview String?
  optedOutAt             DateTime?
  optedInAt              DateTime?
  lastUpdatedAt          DateTime         @default(now())
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  metadataJson           Json?

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  customer Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)
  lead     Lead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@unique([orgId, phoneE164])
  @@index([orgId, status])
  @@index([leadId])
  @@index([customerId])
  @@index([orgId, updatedAt])
}

model SmsDispatchQueue {
  id             String          @id @default(uuid())
  orgId          String
  leadId         String
  kind           SmsDispatchKind @default(AUTOMATION_GENERIC)
  messageType    MessageType     @default(AUTOMATION)
  fromNumberE164 String
  toNumberE164   String
  body           String
  sendAfterAt    DateTime
  status         MessageStatus   @default(QUEUED)
  attemptCount   Int             @default(0)
  lastError      String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  lead Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([orgId, status, sendAfterAt])
  @@index([leadId, createdAt])
  @@index([status, sendAfterAt])
}

model Customer {
  id              String   @id @default(uuid())
  orgId           String
  createdByUserId String?
  name            String
  phoneE164       String
  email           String?
  addressLine     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  org                   Organization           @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdBy             User?                  @relation("CustomerCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  leads                 Lead[]
  events                Event[]
  communicationEvents   CommunicationEvent[]   @relation("CommunicationEventContact")
  voicemailArtifacts    VoicemailArtifact[]    @relation("VoicemailArtifactContact")
  invoices              Invoice[]
  jobs                  Job[]
  recurringServicePlans RecurringServicePlan[]
  portalAccount         CustomerPortalAccount?
  smsConsents           SmsConsent[]
  buyerProjects         BuyerProject[]
  contractProjects      ContractProject[]

  @@index([orgId, phoneE164])
  @@index([orgId, name])
  @@index([orgId, createdAt])
}

model BuyerProject {
  id                        String            @id @default(uuid())
  orgId                     String
  customerId                String?
  leadId                    String?           @unique
  projectType               BuyerProjectType  @default(UNKNOWN)
  currentStage              BuyerProjectStage @default(COMPARE_HOMES)
  projectName               String
  buyerName                 String
  phoneE164                 String?
  email                     String?
  selectedHomeSlug          String?
  selectedHomeTitle         String?
  selectedHomeType          String?
  selectedHomeTypeSlug      String?
  selectedHomeCollection    String?
  selectedHomePriceLabel    String?
  selectedHomeBeds          Int?
  selectedHomeBathsLabel    String?
  selectedHomeSqft          Int?
  selectedHomeStatus        String?
  selectedHomeLocationLabel String?
  selectedHomeModelSeries   String?
  selectedHomeUrl           String?
  sourcePath                String?
  sourcePageTitle           String?
  budgetRange               String?
  financingStatus           String?
  landStatus                String?
  timeline                  String?
  buyerGoal                 String?
  smsOptIn                  Boolean           @default(false)
  buyerNextStep             String?
  internalNextStep          String?
  publicNotes               String?
  createdAt                 DateTime          @default(now())
  updatedAt                 DateTime          @updatedAt

  org             Organization            @relation(fields: [orgId], references: [id], onDelete: Cascade)
  customer        Customer?               @relation(fields: [customerId], references: [id], onDelete: SetNull)
  lead            Lead?                   @relation(fields: [leadId], references: [id], onDelete: SetNull)
  shareLinks      BuyerProjectShareLink[]
  contractProject ContractProject?

  @@index([orgId, currentStage, updatedAt])
  @@index([orgId, projectType, updatedAt])
  @@index([customerId, updatedAt])
  @@index([selectedHomeSlug])
}

model BuyerProjectShareLink {
  id              String    @id @default(uuid())
  orgId           String
  buyerProjectId  String
  createdByUserId String?
  tokenHash       String    @unique
  revokedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  buyerProject BuyerProject @relation(fields: [buyerProjectId], references: [id], onDelete: Cascade)
  createdBy    User?        @relation("BuyerProjectShareLinkCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([orgId, createdAt])
  @@index([buyerProjectId, createdAt])
  @@index([createdByUserId, createdAt])
  @@index([revokedAt, createdAt])
}

model ContractProject {
  id                    String                 @id @default(uuid())
  orgId                 String
  buyerProjectId        String                 @unique
  customerId            String?
  leadId                String?
  createdByUserId       String?
  contractStatus        ContractProjectStatus  @default(DRAFT)
  changeOrderStatus     ChangeOrderStatus      @default(NONE)
  paymentStatus         PaymentMilestoneStatus @default(DEPOSIT_PENDING)
  contractDocumentUrl   String?
  contractDocumentLabel String?
  depositDueCents       Int?
  depositPaidAt         DateTime?
  contractSignedAt      DateTime?
  activeStartedAt       DateTime?
  completedAt           DateTime?
  contractNotes         String?
  internalNextStep      String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  buyerProject BuyerProject @relation(fields: [buyerProjectId], references: [id], onDelete: Cascade)
  customer     Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)
  lead         Lead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)
  createdBy    User?        @relation("ContractProjectCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([orgId, contractStatus, updatedAt])
  @@index([orgId, paymentStatus, updatedAt])
  @@index([orgId, changeOrderStatus, updatedAt])
  @@index([customerId, updatedAt])
  @@index([leadId, updatedAt])
  @@index([createdByUserId, createdAt])
}

model Call {
  id                 String            @id @default(uuid())
  orgId              String
  leadId             String?
  fromNumberE164     String
  toNumberE164       String
  trackingNumberE164 String?
  landingPageUrl     String?
  utmCampaign        String?
  gclid              String?
  attributionSource  AttributionSource @default(UNKNOWN)
  direction          CallDirection
  status             CallStatus
  twilioCallSid      String?           @unique
  startedAt          DateTime
  endedAt            DateTime?
  createdAt          DateTime          @default(now())

  org                 Organization         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  lead                Lead?                @relation(fields: [leadId], references: [id], onDelete: SetNull)
  communicationEvents CommunicationEvent[]
  voicemailArtifacts  VoicemailArtifact[]

  @@index([orgId, startedAt])
  @@index([leadId, startedAt])
}

/// Legacy/provider SMS transport record. CommunicationEvent is the canonical
/// communication audit stream; Message remains for provider compatibility detail.
model Message {
  id                 String           @id @default(uuid())
  orgId              String
  leadId             String
  direction          MessageDirection
  type               MessageType      @default(MANUAL)
  fromNumberE164     String
  toNumberE164       String
  body               String
  provider           MessageProvider  @default(TWILIO)
  providerMessageSid String?          @unique
  status             MessageStatus?
  createdAt          DateTime         @default(now())

