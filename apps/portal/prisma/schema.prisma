  @@unique([orgId, invoiceNumber])
  @@index([orgId, status, dueDate])
  @@index([sourceEstimateId, createdAt])
  @@index([sourceJobId, createdAt])
  @@index([legacyLeadId, createdAt], map: "Invoice_jobId_createdAt_idx")
  @@index([customerId, createdAt])
}

