generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Organization {
  id                          String          @id @default(uuid())
  name                        String
  legalName                   String?
  addressLine1                String?
  addressLine2                String?
  city                        String?
  state                       String?
  zip                         String?
  phone                       String?
  email                       String?
  website                     String?
  licenseNumber               String?
  ein                         String?
  purchaseOrderPrefix         String          @default("PO")
  purchaseOrderNextNumber     Int             @default(1)
  estimatePrefix              String          @default("EST")
  estimateNextNumber          Int             @default(1)
  invoicePrefix               String          @default("INV")
  invoiceNextNumber           Int             @default(1)
  invoicePaymentInstructions  String?
  logoPhotoId                 String?         @unique
  invoiceSequence             Int             @default(0)
  ghostBustingEnabled         Boolean         @default(false)
  voiceNotesEnabled           Boolean         @default(false)
  metaCapiEnabled             Boolean         @default(false)
  offlineModeEnabled          Boolean         @default(false)
  ghostBustingQuietHoursStart Int             @default(1260)
  ghostBustingQuietHoursEnd   Int             @default(480)
  ghostBustingMaxNudges       Int             @default(2)
  ghostBustingTemplateText    String?
  allowWorkerLeadCreate       Boolean         @default(true)
  onboardingStep              Int             @default(0)
  onboardingCompletedAt       DateTime?
  onboardingSkippedAt         DateTime?
  smsFromNumberE164           String?
  smsMonthlyLimit             Int             @default(3000)
  smsHardStop                 Boolean         @default(true)
  aiMonthlyBudgetCents        Int             @default(1000)
  aiHardStop                  Boolean         @default(true)
  aiUserDailyRequestLimit     Int             @default(25)
  messageLanguage             MessageLanguage @default(EN)
  smsTone                     SmsTone         @default(FRIENDLY)
  autoReplyEnabled            Boolean         @default(true)
  followUpsEnabled            Boolean         @default(true)
  autoBookingEnabled          Boolean         @default(true)
  smsGreetingLine             String?
  smsWorkingHoursText         String?
  smsWebsiteSignature         String?
  smsQuietHoursStartMinute    Int             @default(480)
  smsQuietHoursEndMinute      Int             @default(1200)
  missedCallAutoReplyOn       Boolean         @default(false)
  missedCallAutoReplyBody     String?
  missedCallAutoReplyBodyEn   String?
  missedCallAutoReplyBodyEs   String?
  intakeAutomationEnabled     Boolean         @default(false)
  intakeAskLocationBody       String?
  intakeAskLocationBodyEn     String?
  intakeAskLocationBodyEs     String?
  intakeAskWorkTypeBody       String?
  intakeAskWorkTypeBodyEn     String?
  intakeAskWorkTypeBodyEs     String?
  intakeAskCallbackBody       String?
  intakeAskCallbackBodyEn     String?
  intakeAskCallbackBodyEs     String?
  intakeCompletionBody        String?
  intakeCompletionBodyEn      String?
  intakeCompletionBodyEs      String?
  createdAt                   DateTime        @default(now())

  users                    User[]
  customers                Customer[]
  leads                    Lead[]
  jobs                     Job[]
  calls                    Call[]
  messages                 Message[]
  events                   Event[]
  communicationEvents      CommunicationEvent[]
  voicemailArtifacts       VoicemailArtifact[]
  smsTemplates             SmsTemplate[]
  dashboardConfig          OrgDashboardConfig?
  budgetRequests           BudgetRequest[]
  adSpendEntries           AdSpendEntry[]
  marketingSpends          MarketingSpend[]
  leadNotes                LeadNote[]
  leadPhotos               LeadPhoto[]
  photos                   Photo[]
  leadMeasurements         LeadMeasurement[]
  integrationAccounts      IntegrationAccount[]
  integrationOAuthStates   IntegrationOAuthState[]
  importRuns               ImportRun[]
  portableCustomers        PortableCustomer[]
  portableJobs             PortableJob[]
  portableInvoices         PortableInvoice[]
  portableInvoiceLineItems PortableInvoiceLineItem[]
  portablePayments         PortablePayment[]
  portableNotes            PortableNote[]
  calendarWorkerHours      WorkingHours[]
  calendarTimeOff          TimeOff[]
  calendarHolds            CalendarHold[]
  calendarEventWorkers     CalendarEventWorker[]
  googleAccounts           GoogleAccount[]
  googleOAuthStates        GoogleOAuthState[]
  googleSyncJobs           GoogleSyncJob[]
  googleSyncJobAttempts    GoogleSyncJobAttempt[]
  invoices                 Invoice[]
  purchaseOrders           PurchaseOrder[]
  businessExpenses         BusinessExpense[]
  estimates                Estimate[]
  estimateShareLinks       EstimateShareLink[]
  jobTrackingLinks         JobTrackingLink[]
  estimateDrafts           EstimateDraft[]
  crews                    Crew[]
  materials                Material[]
  jobEvents                JobEvent[]
  jobMeasurements          JobMeasurement[]
  jobMaterials             JobMaterial[]
  jobLabor                 JobLabor[]
  cronRunLogs              InternalCronRunLog[]
  metaCapiEvents           MetaCapiEvent[]
  clientMutationReceipts   ClientMutationReceipt[]
  usageByMonth             OrganizationUsage[]
  aiUsageByMonth           AiUsage[]
  aiUserDayUsage           AiUserDayUsage[]
  smsDispatchQueue         SmsDispatchQueue[]
  leadConversationStates   LeadConversationState[]
  leadConversationAudits   LeadConversationAuditEvent[]
  messagingSettings        OrganizationMessagingSettings?
  twilioConfig             OrganizationTwilioConfig?
  twilioConfigAuditLogs    TwilioConfigAuditLog[]

  logoPhoto Photo? @relation("OrganizationLogo", fields: [logoPhotoId], references: [id], onDelete: SetNull)
}

model User {
  id                 String             @id @default(uuid())
  name               String?
  email              String             @unique
  phoneE164          String?
  role               Role               @default(CLIENT)
  calendarAccessRole CalendarAccessRole @default(WORKER)
  timezone           String?
  orgId              String?
  passwordHash       String?
  mustChangePassword Boolean            @default(false)
  emailVerified      DateTime?
  createdAt          DateTime           @default(now())

  org                       Organization?          @relation(fields: [orgId], references: [id])
  assignedLeads             Lead[]                 @relation("LeadAssignee")
  assignedEvents            Event[]                @relation("EventAssignee")
  requestedBudgetChanges    BudgetRequest[]        @relation("BudgetRequestRequester")
  reviewedBudgetChanges     BudgetRequest[]        @relation("BudgetRequestReviewer")
  adSpendEntries            AdSpendEntry[]         @relation("AdSpendEntryCreator")
  marketingSpends           MarketingSpend[]       @relation("MarketingSpendCreator")
  createdLeads              Lead[]                 @relation("LeadCreator")
  createdCustomers          Customer[]             @relation("CustomerCreator")
  leadNotes                 LeadNote[]             @relation("LeadNoteCreator")
  leadPhotos                LeadPhoto[]            @relation("LeadPhotoCreator")
  leadMeasurements          LeadMeasurement[]      @relation("LeadMeasurementCreator")
  calendarCreatedEvents     Event[]                @relation("EventCreator")
  calendarAssignedEvents    CalendarEventWorker[]  @relation("CalendarEventWorker")
  workingHours              WorkingHours[]         @relation("WorkingHoursWorker")
  timeOffEntries            TimeOff[]              @relation("TimeOffWorker")
  calendarHolds             CalendarHold[]         @relation("CalendarHoldWorker")
  createdCalendarHolds      CalendarHold[]         @relation("CalendarHoldCreator")
  googleAccounts            GoogleAccount[]        @relation("GoogleAccountUser")
  googleOAuthStates         GoogleOAuthState[]     @relation("GoogleOAuthStateUser")
  googleSyncJobs            GoogleSyncJob[]        @relation("GoogleSyncJobUser")
  googleSyncRunsTriggered   GoogleSyncRun[]        @relation("GoogleSyncRunTrigger")
  googleSyncJobAttempts     GoogleSyncJobAttempt[] @relation("GoogleSyncJobAttemptUser")
  createdInvoices           Invoice[]              @relation("InvoiceCreator")
  createdPurchaseOrders     PurchaseOrder[]        @relation("PurchaseOrderCreator")
  createdBusinessExpenses   BusinessExpense[]      @relation("BusinessExpenseCreator")
  createdEstimates          Estimate[]             @relation("EstimateCreator")
  createdEstimateShareLinks EstimateShareLink[]    @relation("EstimateShareCreator")
  createdJobTrackingLinks   JobTrackingLink[]      @relation("JobTrackingLinkCreator")
  createdEstimateDrafts     EstimateDraft[]        @relation("EstimateDraftCreator")
  createdJobs               Job[]                  @relation("JobCreator")
  jobEvents                 JobEvent[]             @relation("JobEventActor")
  estimateActivities        EstimateActivity[]     @relation("EstimateActivityActor")
  accounts                  Account[]
  sessions                  Session[]
  resetTokens               PasswordResetToken[]
  aiUserDayUsage            AiUserDayUsage[]
  communicationEvents       CommunicationEvent[]   @relation("CommunicationEventActor")
  twilioConfigAuditLogs     TwilioConfigAuditLog[] @relation("TwilioConfigAuditActor")

  @@index([orgId])
}

model Lead {
  id                        String                 @id @default(uuid())
  orgId                     String
  customerId                String?
  createdByUserId           String?
  assignedToUserId          String?
  status                    LeadStatus             @default(NEW)
  priority                  LeadPriority           @default(MEDIUM)
  businessName              String?
  contactName               String?
  phoneE164                 String
  sourceType                LeadSourceType         @default(ORGANIC)
  preferredLanguage         LeadPreferredLanguage?
  sourceDetail              String?
  sourceChannel             LeadSourceChannel      @default(OTHER)
  utmSource                 String?
  utmMedium                 String?
  utmCampaign               String?
  attributionLocked         Boolean                @default(true)
  commissionEligible        Boolean                @default(false)
  city                      String?
  businessType              String?
  leadSource                LeadSource             @default(OTHER)
  firstContactedAt          DateTime?
  lastContactedAt           DateTime?
  lastInboundAt             DateTime?
  lastOutboundAt            DateTime?
  ghostNudgeCount           Int                    @default(0)
  lastGhostNudgeAt          DateTime?
  nextFollowUpAt            DateTime?
  intakeStage               LeadIntakeStage        @default(NONE)
  intakeLocationText        String?
  intakeWorkTypeText        String?
  intakePreferredCallbackAt DateTime?
  estimatedRevenueCents     Int?
  invoiceStatus             InvoiceStatus          @default(NONE)
  invoiceDraftText          String?
  invoiceDueAt              DateTime?
  invoiceLastAutoTaskAt     DateTime?
  notes                     String?
  latestEstimateId          String?
  estimateCount             Int                    @default(0)
  fbClickId                 String?
  fbBrowserId               String?
  createdAt                 DateTime               @default(now())
  updatedAt                 DateTime               @updatedAt

  org                 Organization                 @relation(fields: [orgId], references: [id], onDelete: Cascade)
  customer            Customer?                    @relation(fields: [customerId], references: [id], onDelete: SetNull)
  createdBy           User?                        @relation("LeadCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  assignedTo          User?                        @relation("LeadAssignee", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  calls               Call[]
  messages            Message[]
  events              Event[]
  jobs                Job[]
  communicationEvents CommunicationEvent[]
  voicemailArtifacts  VoicemailArtifact[]
  leadNotes           LeadNote[]
  leadPhotos          LeadPhoto[]
  measurements        LeadMeasurement[]
  estimates           Estimate[]                   @relation("EstimateLead")
  latestEstimate      Estimate?                    @relation("LeadLatestEstimate", fields: [latestEstimateId], references: [id], onDelete: SetNull)
  calendarHolds       CalendarHold[]
  invoices            Invoice[]
  metaCapiEvents      MetaCapiEvent[]
  smsDispatchQueue    SmsDispatchQueue[]
  conversationState   LeadConversationState?
  conversationAudits  LeadConversationAuditEvent[]

  @@index([orgId, status, createdAt])
  @@index([orgId, nextFollowUpAt])
  @@index([orgId, intakeStage])
  @@index([assignedToUserId, nextFollowUpAt])
  @@index([orgId, lastInboundAt])
  @@index([orgId, lastOutboundAt])
  @@index([orgId, ghostNudgeCount, lastGhostNudgeAt])
  @@index([orgId, invoiceStatus, updatedAt])
  @@index([latestEstimateId])
  @@index([customerId, updatedAt])
  @@index([createdByUserId, createdAt])
  @@index([orgId, sourceType, createdAt])
  @@index([orgId, sourceChannel, createdAt])
}

model SmsDispatchQueue {
  id             String          @id @default(uuid())
  orgId          String
  leadId         String
  kind           SmsDispatchKind @default(AUTOMATION_GENERIC)
  messageType    MessageType     @default(AUTOMATION)
  fromNumberE164 String
  toNumberE164   String
  body           String
  sendAfterAt    DateTime
  status         MessageStatus   @default(QUEUED)
  attemptCount   Int             @default(0)
  lastError      String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  lead Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([orgId, status, sendAfterAt])
  @@index([leadId, createdAt])
  @@index([status, sendAfterAt])
}

model Customer {
  id              String   @id @default(uuid())
  orgId           String
  createdByUserId String?
  name            String
  phoneE164       String
  email           String?
  addressLine     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  org                 Organization         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdBy           User?                @relation("CustomerCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  leads               Lead[]
  events              Event[]
  communicationEvents CommunicationEvent[] @relation("CommunicationEventContact")
  voicemailArtifacts  VoicemailArtifact[]  @relation("VoicemailArtifactContact")
  invoices            Invoice[]
  jobs                Job[]

  @@index([orgId, phoneE164])
  @@index([orgId, name])
  @@index([orgId, createdAt])
}

model Call {
  id                 String            @id @default(uuid())
  orgId              String
  leadId             String?
  fromNumberE164     String
  toNumberE164       String
  trackingNumberE164 String?
  landingPageUrl     String?
  utmCampaign        String?
  gclid              String?
  attributionSource  AttributionSource @default(UNKNOWN)
  direction          CallDirection
  status             CallStatus
  twilioCallSid      String?           @unique
  startedAt          DateTime
  endedAt            DateTime?
  createdAt          DateTime          @default(now())

  org                 Organization         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  lead                Lead?                @relation(fields: [leadId], references: [id], onDelete: SetNull)
  communicationEvents CommunicationEvent[]
  voicemailArtifacts  VoicemailArtifact[]

  @@index([orgId, startedAt])
  @@index([leadId, startedAt])
}

model Message {
  id                 String           @id @default(uuid())
  orgId              String
  leadId             String
  direction          MessageDirection
  type               MessageType      @default(MANUAL)
  fromNumberE164     String
  toNumberE164       String
  body               String
  provider           MessageProvider  @default(TWILIO)
  providerMessageSid String?          @unique
  status             MessageStatus?
  createdAt          DateTime         @default(now())

  org                 Organization         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  lead                Lead                 @relation(fields: [leadId], references: [id], onDelete: Cascade)
  communicationEvents CommunicationEvent[]

  @@index([orgId, createdAt])
  @@index([leadId, createdAt])
  @@index([leadId, type, createdAt])
}

model CommunicationEvent {
  id                    String                 @id @default(uuid())
  orgId                 String
  leadId                String?
  contactId             String?
  conversationId        String?
  callId                String?
  messageId             String?
  actorUserId           String?
  type                  CommunicationEventType
  channel               CommunicationChannel
  occurredAt            DateTime
  summary               String
  metadataJson          Json?
  provider              String?
  providerCallSid       String?
  providerParentCallSid String?
  providerMessageSid    String?
  providerStatus        String?
  idempotencyKey        String
  createdAt             DateTime               @default(now())

  org               Organization           @relation(fields: [orgId], references: [id], onDelete: Cascade)
  lead              Lead?                  @relation(fields: [leadId], references: [id], onDelete: SetNull)
  contact           Customer?              @relation("CommunicationEventContact", fields: [contactId], references: [id], onDelete: SetNull)
  conversation      LeadConversationState? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  call              Call?                  @relation(fields: [callId], references: [id], onDelete: SetNull)
  message           Message?               @relation(fields: [messageId], references: [id], onDelete: SetNull)
  actor             User?                  @relation("CommunicationEventActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  voicemailArtifact VoicemailArtifact?

  @@unique([orgId, idempotencyKey])
  @@index([orgId, occurredAt])
  @@index([leadId, occurredAt])
  @@index([contactId, occurredAt])
  @@index([conversationId, occurredAt])
  @@index([callId, occurredAt])
  @@index([messageId, occurredAt])
  @@index([providerCallSid, occurredAt])
  @@index([providerMessageSid, occurredAt])
}

model VoicemailArtifact {
  id                       String                        @id @default(uuid())
  orgId                    String
  leadId                   String?
  contactId                String?
  conversationId           String?
  callId                   String?
  communicationEventId     String                        @unique
  providerCallSid          String?
  recordingSid             String?                       @unique
  recordingUrl             String?
  recordingDurationSeconds Int?
  transcriptionStatus      VoicemailTranscriptionStatus?
  transcriptionText        String?
  voicemailAt              DateTime
  metadataJson             Json?
  createdAt                DateTime                      @default(now())
  updatedAt                DateTime                      @updatedAt

  org                Organization           @relation(fields: [orgId], references: [id], onDelete: Cascade)
  lead               Lead?                  @relation(fields: [leadId], references: [id], onDelete: SetNull)
  contact            Customer?              @relation("VoicemailArtifactContact", fields: [contactId], references: [id], onDelete: SetNull)
  conversation       LeadConversationState? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  call               Call?                  @relation(fields: [callId], references: [id], onDelete: SetNull)
  communicationEvent CommunicationEvent     @relation(fields: [communicationEventId], references: [id], onDelete: Cascade)

  @@index([orgId, voicemailAt])
  @@index([leadId, voicemailAt])
  @@index([contactId, voicemailAt])
  @@index([conversationId, voicemailAt])
  @@index([callId, voicemailAt])
  @@index([providerCallSid, voicemailAt])
}

model SmsTemplate {
  id        String   @id @default(uuid())
  orgId     String
  name      String
  body      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, isActive, createdAt])
}

model Event {
  id               String              @id @default(uuid())
  orgId            String
  leadId           String?
  customerId       String?
  type             EventType
  provider         EventProvider       @default(LOCAL)
  googleEventId    String?
  googleCalendarId String?
  syncStatus       EventSyncStatus     @default(PENDING)
  lastSyncedAt     DateTime?
  status           CalendarEventStatus @default(SCHEDULED)
  busy             Boolean             @default(true)
  customerName     String?
  addressLine      String?
  allDay           Boolean             @default(false)
  title            String
  description      String?
  startAt          DateTime
  endAt            DateTime?
  assignedToUserId String?
  createdByUserId  String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  org               Organization          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  lead              Lead?                 @relation(fields: [leadId], references: [id], onDelete: SetNull)
  customer          Customer?             @relation(fields: [customerId], references: [id], onDelete: SetNull)
  assignedTo        User?                 @relation("EventAssignee", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  createdBy         User?                 @relation("EventCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  workerAssignments CalendarEventWorker[]
  googleSyncJobs    GoogleSyncJob[]       @relation("GoogleSyncJobEvent")

  @@unique([orgId, googleCalendarId, googleEventId])
  @@index([orgId, startAt])
  @@index([assignedToUserId, startAt])
  @@index([orgId, type, startAt])
  @@index([orgId, provider, startAt])
  @@index([assignedToUserId, provider, startAt])
  @@index([customerId, startAt])
}

model Invoice {
  id               String               @id @default(uuid())
  orgId            String
  jobId            String?
  sourceEstimateId String?
  sourceJobId      String?
  customerId       String
  invoiceNumber    String
  terms            InvoiceTerms         @default(DUE_ON_RECEIPT)
  status           BillingInvoiceStatus @default(DRAFT)
  subtotal         Decimal              @default(0) @db.Decimal(12, 2)
  taxRate          Decimal              @default(0) @db.Decimal(6, 4)
  taxAmount        Decimal              @default(0) @db.Decimal(12, 2)
  total            Decimal              @default(0) @db.Decimal(12, 2)
  amountPaid       Decimal              @default(0) @db.Decimal(12, 2)
  balanceDue       Decimal              @default(0) @db.Decimal(12, 2)
  issueDate        DateTime
  dueDate          DateTime
  notes            String?
  createdByUserId  String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  org            Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  job            Lead?             @relation(fields: [jobId], references: [id], onDelete: SetNull)
  sourceEstimate Estimate?         @relation("EstimateSourceInvoice", fields: [sourceEstimateId], references: [id], onDelete: SetNull)
  sourceJob      Job?              @relation("InvoiceSourceJob", fields: [sourceJobId], references: [id], onDelete: SetNull)
  customer       Customer          @relation(fields: [customerId], references: [id], onDelete: Restrict)
  createdBy      User?             @relation("InvoiceCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  lineItems      InvoiceLineItem[]
  payments       InvoicePayment[]
  metaCapiEvents MetaCapiEvent[]

  @@unique([orgId, invoiceNumber])
  @@index([orgId, status, dueDate])
  @@index([sourceEstimateId, createdAt])
  @@index([sourceJobId, createdAt])
  @@index([jobId, createdAt])
  @@index([customerId, createdAt])
}

model InvoiceLineItem {
  id          String   @id @default(uuid())
  invoiceId   String
  description String
  quantity    Decimal  @default(1) @db.Decimal(10, 2)
  unitPrice   Decimal  @default(0) @db.Decimal(12, 2)
  lineTotal   Decimal  @default(0) @db.Decimal(12, 2)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId, sortOrder])
}

model InvoicePayment {
  id        String               @id @default(uuid())
  invoiceId String
  amount    Decimal              @default(0) @db.Decimal(12, 2)
  date      DateTime
  method    InvoicePaymentMethod
  note      String?
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId, date])
}

model PurchaseOrder {
  id              String              @id @default(uuid())
  orgId           String
  jobId           String?
  createdByUserId String?
  poNumber        String
  vendorName      String
  vendorEmail     String?
  vendorPhone     String?
  vendorAddress   String?
  title           String
  status          PurchaseOrderStatus @default(DRAFT)
  notes           String?
  subtotal        Decimal             @default(0) @db.Decimal(12, 2)
  taxRate         Decimal             @default(0) @db.Decimal(6, 4)
  taxAmount       Decimal             @default(0) @db.Decimal(12, 2)
  total           Decimal             @default(0) @db.Decimal(12, 2)
  sentAt          DateTime?
  receivedAt      DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  org       Organization            @relation(fields: [orgId], references: [id], onDelete: Cascade)
  job       Job?                    @relation(fields: [jobId], references: [id], onDelete: SetNull)
  createdBy User?                   @relation("PurchaseOrderCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  lineItems PurchaseOrderLineItem[]
  expenses  BusinessExpense[]

  @@unique([orgId, poNumber])
  @@index([orgId, status, updatedAt])
  @@index([jobId, updatedAt])
  @@index([createdByUserId, updatedAt])
}

model PurchaseOrderLineItem {
  id              String   @id @default(uuid())
  purchaseOrderId String
  materialId      String?
  sortOrder       Int      @default(0)
  name            String
  description     String?
  quantity        Decimal  @default(1) @db.Decimal(10, 2)
  unit            String?
  unitCost        Decimal  @default(0) @db.Decimal(12, 2)
  total           Decimal  @default(0) @db.Decimal(12, 2)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  material      Material?     @relation(fields: [materialId], references: [id], onDelete: SetNull)

  @@index([purchaseOrderId, sortOrder])
  @@index([materialId])
}

model BusinessExpense {
  id              String   @id @default(uuid())
  orgId           String
  jobId           String?
  purchaseOrderId String?
  createdByUserId String?
  receiptPhotoId  String?
  expenseDate     DateTime
  vendorName      String?
  category        String
  description     String
  amount          Decimal  @default(0) @db.Decimal(12, 2)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  org           Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  job           Job?           @relation(fields: [jobId], references: [id], onDelete: SetNull)
  purchaseOrder PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)
  createdBy     User?          @relation("BusinessExpenseCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  receiptPhoto  Photo?         @relation("BusinessExpenseReceipt", fields: [receiptPhotoId], references: [id], onDelete: SetNull)

  @@index([orgId, expenseDate])
  @@index([jobId, createdAt])
  @@index([purchaseOrderId, createdAt])
