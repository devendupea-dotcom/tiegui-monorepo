  @@unique([orgId, googleCalendarId, googleEventId])
  @@index([orgId, startAt])
  @@index([assignedToUserId, startAt])
  @@index([orgId, type, startAt])
  @@index([orgId, provider, startAt])
  @@index([assignedToUserId, provider, startAt])
  @@index([jobId, startAt])
  @@index([customerId, startAt])
}

model Invoice {
  id                 String               @id @default(uuid())
  orgId              String
  /// Legacy CRM lead link preserved for compatibility. Operational invoice truth lives on sourceJobId.
  legacyLeadId       String?              @map("jobId")
  sourceEstimateId   String?
  sourceJobId        String?
  customerId         String
  invoiceNumber      String
  terms              InvoiceTerms         @default(DUE_ON_RECEIPT)
  status             BillingInvoiceStatus @default(DRAFT)
  subtotal           Decimal              @default(0) @db.Decimal(12, 2)
  taxRate            Decimal              @default(0) @db.Decimal(6, 4)
  taxAmount          Decimal              @default(0) @db.Decimal(12, 2)
  total              Decimal              @default(0) @db.Decimal(12, 2)
  amountPaid         Decimal              @default(0) @db.Decimal(12, 2)
  balanceDue         Decimal              @default(0) @db.Decimal(12, 2)
  issueDate          DateTime
  dueDate            DateTime
  notes              String?
  sentAt             DateTime?
  lastReminderSentAt DateTime?
  reminderCount      Int                  @default(0)
  createdByUserId    String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  org                Organization               @relation(fields: [orgId], references: [id], onDelete: Cascade)
  legacyLead         Lead?                      @relation(fields: [legacyLeadId], references: [id], onDelete: SetNull)
  sourceEstimate     Estimate?                  @relation("EstimateSourceInvoice", fields: [sourceEstimateId], references: [id], onDelete: SetNull)
  sourceJob          Job?                       @relation("InvoiceSourceJob", fields: [sourceJobId], references: [id], onDelete: SetNull)
  customer           Customer                   @relation(fields: [customerId], references: [id], onDelete: Restrict)
  createdBy          User?                      @relation("InvoiceCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
