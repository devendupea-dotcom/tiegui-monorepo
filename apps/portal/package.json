{
  "name": "portal",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack --port 3001",
    "build": "prisma generate && NEXT_IGNORE_INCORRECT_LOCKFILE=1 next build --webpack",
    "prestart": "node scripts/check-migrations.mjs",
    "start": "next start",
    "lint": "eslint . --quiet",
    "lint:warnings": "eslint .",
    "check-types": "prisma generate && tsc --noEmit",
    "test": "node --import tsx --test tests/*.test.mjs",
    "backfill:communication-events": "ts-node scripts/backfill-communication-events.ts",
    "backfill:event-job-links": "node --import tsx scripts/backfill-event-job-links.ts",
    "backfill:invoice-source-jobs": "node --import tsx scripts/backfill-invoice-source-jobs.ts",
    "backfill:lead-customers": "node --import tsx scripts/backfill-lead-customers.ts",
    "backfill:sms-consent": "node --import tsx scripts/backfill-sms-consent-from-legacy-dnc.ts",
    "backfill:tenant-access": "node --import tsx scripts/backfill-tenant-access.ts",
    "diagnose:communication-integrity": "node --import tsx scripts/repair-communication-integrity.ts",
    "diagnose:estimate-job-links": "node --import tsx scripts/diagnose-estimate-job-links.ts",
    "diagnose:financial-integrity": "node --import tsx scripts/diagnose-financial-integrity.ts",
    "diagnose:lead-conversation-integrity": "node --import tsx scripts/diagnose-lead-conversation-integrity.ts",
    "diagnose:operational-integrity": "node --import tsx scripts/diagnose-operational-integrity.ts",
    "check:release-env": "tsx scripts/check-release-env.ts",
    "check:collections-cron": "tsx scripts/check-invoice-collections-cron.ts",
    "repair:communication-integrity": "APPLY=1 node --import tsx scripts/repair-communication-integrity.ts",
    "repair:zero-paid-invoices": "node --import tsx scripts/repair-zero-paid-invoices.ts",
    "sanitize:legacy-leads": "node --import tsx scripts/sanitize-legacy-leads.ts",
    "smoke:portal": "tsx scripts/smoke-portal.ts",
    "smoke:website-leads": "tsx scripts/smoke-website-leads.ts",
    "test:timezone": "node --import tsx --test tests/timezone-dst.test.mjs",
    "db:validate": "node scripts/validate-prisma.mjs",
    "db:migrate:deploy": "node scripts/migrate-deploy.mjs",
    "db:seed": "node scripts/seed-direct.mjs",
    "provision:endeavor": "node scripts/provision-endeavor-builder.mjs",
    "seed:endeavor-demo": "node scripts/seed-endeavor-demo-projects.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.990.0",
    "@aws-sdk/s3-request-presigner": "^3.990.0",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^5.22.0",
    "@react-pdf/renderer": "^3.4.4",
    "@repo/ui": "*",
    "@sentry/nextjs": "^10.50.0",
    "@serwist/next": "^9.5.5",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-persist-client": "^5.90.22",
    "@types/bcryptjs": "^2.4.6",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.2",
    "bcryptjs": "^3.0.3",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "idb-keyval": "^6.2.2",
    "next": "^16.2.4",
    "next-auth": "^4.24.14",
    "next-intl": "^4.9.1",
    "openai": "^6.34.0",
    "papaparse": "^5.5.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "read-excel-file": "^9.0.6",
    "resend": "^4.8.0",
    "serwist": "^9.5.5",
    "stripe": "^22.0.2"
  },
  "devDependencies": {
    "@repo/eslint-config": "*",
    "@repo/typescript-config": "*",
    "@types/node": "^22.15.3",
    "@types/papaparse": "^5.5.2",
    "@types/react": "19.2.10",
    "@types/react-dom": "19.2.3",
    "eslint": "^9.39.1",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "5.9.2"
  },
  "ts-node": {
    "esm": true,
    "experimentalSpecifierResolution": "node"
  }
}
