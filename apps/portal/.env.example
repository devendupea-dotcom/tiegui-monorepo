# Core app + database
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
# Prisma tooling requires DIRECT_URL. Set it to DATABASE_URL if you do not use
# a separate direct connection string for migrations and schema checks.
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=replace-me

# Email/auth flows
EMAIL_FROM=noreply@example.com
# Use either SMTP_URL / EMAIL_SERVER or RESEND_API_KEY, depending on the mailer you run.
SMTP_URL=
EMAIL_SERVER=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Your Business Name <noreply@yourdomain.com>"
RESEND_API_KEY=

# Optional admin + observability
ADMIN_EMAILS=
ADMIN_VAULT_KEY=
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Optional storage (recommended for production logos + photos)
PHOTO_STORAGE_PROVIDER=local
AWS_REGION=
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
R2_ACCOUNT_ID=
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# Twilio SMS / Voice (Phase 2)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_TOKEN_ENCRYPTION_KEY=
TWILIO_SEND_ENABLED=false
TWILIO_VALIDATE_SIGNATURE=false
TWILIO_SMS_COST_ESTIMATE_CENTS=1
TWILIO_VOICE_AFTER_CALL_URL=
# Optional; clamped to 12-30 seconds by runtime, defaults to 20 when unset.
TWILIO_VOICE_FORWARD_TIMEOUT_SECONDS=20
CRON_SECRET=

# Stripe billing / collections
STRIPE_SECRET_KEY=
STRIPE_CONNECT_CLIENT_ID=
STRIPE_WEBHOOK_SECRET=
STRIPE_REDIRECT_URI=

# Integrations (Phase 1 readiness UI + Phase 2 sync)
INTEGRATIONS_ENCRYPTION_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/integrations/google/callback
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=
MICROSOFT_REDIRECT_URI=http://localhost:3001/api/integrations/outlook/callback
MICROSOFT_SCOPES=offline_access openid profile email User.Read Mail.Send
JOBBER_CLIENT_ID=
JOBBER_CLIENT_SECRET=
JOBBER_REDIRECT_URI=http://localhost:3001/api/integrations/jobber/callback
JOBBER_SCOPES=read_clients read_jobs read_invoices
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_REDIRECT_URI=http://localhost:3001/api/integrations/qbo/callback
QBO_SCOPES=com.intuit.quickbooks.accounting

# Optional runtime services
META_PIXEL_ID=
META_CAPI_ACCESS_TOKEN=
OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://tiegui-ai.openai.azure.com/
AZURE_OPENAI_API_KEY=
# Leave blank to auto-enable when Azure OpenAI credentials are present. Set false to force the SMS agent off.
CONVERSATIONAL_SMS_LLM_ENABLED=
# Azure OpenAI deployment name
OPENAI_CONVERSATIONAL_SMS_MODEL=sms-agent
OPENAI_CONVERSATIONAL_SMS_COST_ESTIMATE_CENTS=2
OPENAI_WHISPER_COST_CENTS_PER_MINUTE=0
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Local tooling / scripts
BASE_URL=http://127.0.0.1:3001
SMOKE_TIMEOUT_MS=15000
# Optional: lets smoke tests reach protected Vercel Preview deployments.
VERCEL_AUTOMATION_BYPASS_SECRET=
MIGRATE_PHOTOS_BATCH=100
PRISMA_ENV_FILE=

# Platform-provided values (usually injected automatically outside local development)
NODE_ENV=development
VERCEL_ENV=
VERCEL_URL=
VERCEL_PROJECT_PRODUCTION_URL=
VERCEL_GIT_COMMIT_SHA=
VERCEL_GIT_COMMIT_REF=
VERCEL_DEPLOYMENT_ID=
